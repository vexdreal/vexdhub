generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Key {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  active    Boolean  @default(true)
  expiresAt DateTime?

  deviceId  String?
  lastUsed  DateTime?
  useCount  Int      @default(0)

  createdAt DateTime @default(now())
}